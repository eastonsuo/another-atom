LLM_PROVIDER=mock
DATABASE_URL=sqlite:///./data/another_atom.db
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=deepseek-v4-pro
AGENT_STAGE_TIMEOUT_SECONDS=540
PROVIDER_CIRCUIT_BREAKER_SECONDS=300
PROVIDER_PROGRESS_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_SECONDS=30
MAX_SOURCE_CHARS=120000
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_LEAD_TIMEOUT_SECONDS=60
OLLAMA_FAILOVER_TIMEOUT_SECONDS=30
DEEPSEEK_API_KEY=
DEEPSEEK_HOST=https://api.deepseek.com
# Read-only administrator bootstrap. Public demos may keep the defaults, but overrides are recommended.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_DISPLAY_NAME=Another Atom Admin
SESSION_COOKIE_SECURE=false
