LLM_PROVIDER=mock
DATABASE_URL=sqlite:///./data/another_atom.db
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=deepseek-v4-pro
OLLAMA_VISION_MODEL=
# Optional overrides; leave empty to reuse OLLAMA_HOST and OLLAMA_API_KEY.
OLLAMA_VISION_HOST=
OLLAMA_VISION_API_KEY=
VISION_TIMEOUT_SECONDS=120
AGENT_STAGE_TIMEOUT_SECONDS=540
PROVIDER_CIRCUIT_BREAKER_SECONDS=300
PROVIDER_PROGRESS_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_SECONDS=30
MAX_SOURCE_CHARS=120000
MAX_SOURCE_CHANGE_BYTES=240000
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_LEAD_TIMEOUT_SECONDS=60
OLLAMA_FAILOVER_TIMEOUT_SECONDS=30
DEEPSEEK_API_KEY=
DEEPSEEK_HOST=https://api.deepseek.com
# Read-only administrator bootstrap. Public demos may keep the defaults, but overrides are recommended.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_DISPLAY_NAME=Another Atom Admin
SESSION_COOKIE_SECURE=false
# 主服务填写 Railway 私网地址，例如 http://runtime-executor.railway.internal:8001
RUNTIME_EXECUTOR_URL=http://127.0.0.1:8001
# 主服务和独立执行服务必须使用同一条高强度随机值
RUNTIME_EXECUTOR_SHARED_TOKEN=replace-with-a-random-shared-token
RUNTIME_EXECUTOR_TIMEOUT_SECONDS=180
RUNTIME_EXECUTOR_MAX_CONCURRENCY=1
